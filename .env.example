# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional fallback for backend intelligence when Gemini is unavailable.
# Lowest-friction path for this app is to set either GEMINI_API_KEY or OPENAI_API_KEY.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# AI_PROVIDER: auto | gemini | openai
# Leave as auto to prefer Gemini when available and fall back to OpenAI.
AI_PROVIDER="auto"

# OPENAI_MODEL: Use a low-cost text/vision capable model for extraction, trends, and appeal drafts.
OPENAI_MODEL="gpt-4o-mini"

# GEMINI_MODEL: Low-cost Gemini model for structured extraction and analysis.
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: Local dev override so this project can run beside other apps.
PORT="3001"

# AUTOPILOT_ENABLED: keep warehouse seeding and BigQuery -> Neon sync running automatically.
AUTOPILOT_ENABLED="true"

# FIRESTORE_AUTOPILOT_ENABLED: leave false unless you intentionally want the legacy Firestore ingestion engine running.
FIRESTORE_AUTOPILOT_ENABLED="false"
